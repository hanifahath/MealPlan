<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.MealPlan" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_light</item>
        <item name="colorPrimaryVariant">@color/primary_color</item>
        <item name="colorSecondary">@color/primary_light</item>
        <item name="android:colorBackground">#1A1210</item>
        <item name="colorSurface">#2C2320</item>
        <item name="colorOnBackground">@color/text_primary_dark</item>
        <item name="colorOnSurface">@color/text_primary_dark</item>
        <item name="colorOnPrimary">#1A1210</item>
        <item name="colorError">#EF9A9A</item>
        <item name="android:windowBackground">#1A1210</item>
        <item name="cardBackgroundColor">#2C2320</item>
        <item name="bottomNavigationStyle">@style/BottomNavStyleDark</item>
    </style>

    <style name="Theme.MealPlan.Splash" parent="Theme.MealPlan">
        <item name="android:windowBackground">@drawable/splash_background_dark</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="BottomNavStyleDark" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="backgroundTint">#2C2320</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="elevation">8dp</item>
    </style>

    <style name="SectionTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary_dark</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

</resources>