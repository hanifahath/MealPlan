<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- Steps container - diisi programatically dari InstructionsTabFragment -->
        <LinearLayout
            android:id="@+id/container_steps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"/>

        <!-- Fallback: teks biasa kalau tidak ada steps -->
        <TextView
            android:id="@+id/tv_instructions_tab"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.7"
            android:textColor="?attr/colorOnBackground"
            android:visibility="gone"/>
    </LinearLayout>

</androidx.core.widget.NestedScrollView>
