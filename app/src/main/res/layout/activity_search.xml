<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground"
    android:fitsSystemWindows="true">

    <!-- Search bar row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btn_back_search"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="?attr/colorOnBackground"
            android:contentDescription="@string/back"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_search_bar"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="8dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_search"
                app:tint="#9E9E9E"
                android:contentDescription="@null"/>

            <EditText
                android:id="@+id/et_search"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:hint="@string/search_hint"
                android:textSize="14sp"
                android:textColor="?attr/colorOnBackground"
                android:textColorHint="#9E9E9E"
                android:background="@null"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:maxLines="1"/>

            <ImageButton
                android:id="@+id/btn_clear_search"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_close"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#9E9E9E"
                android:visibility="gone"
                android:contentDescription="Hapus"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_color"/>

    <!-- Content: recent search / results -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- State default: recent search -->
        <LinearLayout
            android:id="@+id/layout_recent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/recent_search"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnBackground"
                android:layout_marginBottom="12dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_recent_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- Empty recent -->
            <TextView
                android:id="@+id/tv_no_recent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Belum ada pencarian"
                android:textSize="13sp"
                android:textColor="#9E9E9E"
                android:gravity="center"
                android:layout_marginTop="40dp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- State loading -->
        <ProgressBar
            android:id="@+id/progress_search"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/primary_color"
            android:visibility="gone"/>

        <!-- State hasil pencarian -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_search_results"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:clipToPadding="false"
            android:visibility="gone"/>

        <!-- State tidak ada hasil -->
        <LinearLayout
            android:id="@+id/layout_no_result"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_search"
                app:tint="@color/primary_light"
                android:contentDescription="@null"/>

            <TextView
                android:id="@+id/tv_no_result_query"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnBackground"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Coba kata kunci lain"
                android:textSize="13sp"
                android:textColor="#9E9E9E"/>
        </LinearLayout>

        <!-- State gagal jaringan + tombol coba lagi -->
        <LinearLayout
            android:id="@+id/layout_search_error"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_search"
                app:tint="@color/primary_light"
                android:contentDescription="@null"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/search_load_failed"
                android:textSize="15sp"
                android:gravity="center"
                android:textColor="?attr/colorOnBackground"/>

            <Button
                android:id="@+id/btn_search_retry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/detail_retry"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/primary_color"/>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
