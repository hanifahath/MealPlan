<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <!-- Hero image - fixed height, tidak scroll -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="260dp">

        <ImageView
            android:id="@+id/img_detail_thumb"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="@string/meal_image"/>

        <!-- Gradient atas untuk back button -->
        <View
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@drawable/gradient_top"/>

        <!-- Back button kiri atas -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="14dp"
            android:src="@drawable/ic_back"
            android:background="@drawable/bg_circle_white"
            app:tint="@color/primary_color"
            android:contentDescription="@string/back"/>

        <!-- Share + Favorite kanan bawah gambar -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="14dp"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_share"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_share"
                android:background="@drawable/bg_circle_white"
                app:tint="@color/primary_color"
                android:contentDescription="@string/share"/>

            <ImageButton
                android:id="@+id/btn_favorite"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_heart_outline"
                android:background="@drawable/bg_circle_white"
                app:tint="@color/error_color"
                android:contentDescription="@string/add_favorite"/>
        </LinearLayout>
    </FrameLayout>

    <!-- Info section - nama, badge, youtube -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?android:attr/colorBackground"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tv_detail_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.2"
            android:textColor="?attr/colorOnBackground"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_detail_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_chip_selected"
                android:textColor="#FFFFFF"/>

            <TextView
                android:id="@+id/tv_detail_area"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_chip_normal"
                android:textColor="@color/chip_text_normal"/>
        </LinearLayout>

        <!-- YouTube button -->
        <Button
            android:id="@+id/btn_youtube"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="12dp"
            android:text="▶  Tonton Tutorial di YouTube"
            android:textSize="13sp"
            android:textStyle="bold"
            android:backgroundTint="@android:color/transparent"
            android:textColor="#FF0000"
            android:visibility="gone"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
    </LinearLayout>

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/progress_detail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/primary_color"
        android:visibility="gone"/>

    <!-- Tab: Ingredients | Instructions -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        app:tabSelectedTextColor="@color/primary_color"
        app:tabTextColor="#9E9E9E"
        app:tabIndicatorColor="@color/primary_color"
        app:tabIndicatorHeight="2dp"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabTextAppearance="@style/TabTextAppearance"/>

    <!-- ViewPager untuk tab content -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
