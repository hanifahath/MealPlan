<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/detail_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/app_bg"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsing_toolbar"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            app:contentScrim="@android:color/transparent"
            app:statusBarScrim="@android:color/transparent"
            app:layout_scrollFlags="scroll">

            <ImageView
                android:id="@+id/img_detail_thumb"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:scaleType="centerCrop"
                app:layout_collapseMode="parallax"
                android:contentDescription="@string/meal_image"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/gradient_top"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_gravity="bottom"
                android:background="@drawable/gradient_card_bottom"/>

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="14dp"
                android:padding="9dp"
                android:src="@drawable/ic_back"
                android:background="@drawable/bg_circle_scrim"
                android:scaleType="fitCenter"
                app:tint="#FFFFFF"
                android:contentDescription="@string/back"/>

            <LinearLayout
                android:id="@+id/layout_detail_actions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="14dp"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btn_share"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:padding="9dp"
                    android:src="@drawable/ic_share"
                    android:background="@drawable/bg_circle_scrim"
                    android:scaleType="fitCenter"
                    app:tint="#FFFFFF"
                    android:contentDescription="@string/share"/>

                <ImageButton
                    android:id="@+id/btn_favorite"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="9dp"
                    android:src="@drawable/ic_heart_outline"
                    android:background="@drawable/bg_circle_scrim"
                    android:scaleType="fitCenter"
                    app:tint="#FF6B6B"
                    android:contentDescription="@string/add_favorite"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="18dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="9dp">

                    <TextView
                        android:id="@+id/tv_detail_category"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="11dp"
                        android:paddingEnd="11dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.04"
                        android:background="@drawable/bg_chip_selected"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:id="@+id/tv_detail_area"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:paddingStart="11dp"
                        android:paddingEnd="11dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.04"
                        android:background="@drawable/bg_hero_tag"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_detail_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="1.1"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>
        </com.google.android.material.appbar.CollapsingToolbarLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/app_bg"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="4dp"
            app:layout_scrollFlags="scroll">

            <TextView
                android:id="@+id/tv_lang_note"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/recipe_lang_note"
                android:textSize="11sp"
                android:textColor="@color/text_tertiary"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_youtube"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="12dp"
                android:text="Tonton Tutorial di YouTube"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#FF0000"
                android:visibility="gone"
                app:icon="@drawable/ic_youtube"
                app:iconTint="#FF0000"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:strokeColor="@color/border_color"
                app:cornerRadius="13dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        </LinearLayout>

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/app_bg"
            app:tabSelectedTextColor="@color/primary_color"
            app:tabTextColor="@color/text_tertiary"
            app:tabIndicatorColor="@color/primary_color"
            app:tabIndicatorHeight="2.5dp"
            app:tabIndicatorFullWidth="false"
            app:tabMode="fixed"
            app:tabGravity="fill"
            app:tabTextAppearance="@style/TabTextAppearance"/>
    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        android:id="@+id/detail_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/view_pager"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <ProgressBar
            android:id="@+id/progress_detail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/primary_color"
            android:visibility="gone"/>

        <LinearLayout
            android:id="@+id/layout_detail_error"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/detail_load_failed"
                android:textSize="15sp"
                android:gravity="center"
                android:textColor="@color/text_secondary"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_detail_retry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/detail_retry"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/primary_color"
                app:cornerRadius="13dp"/>
        </LinearLayout>
    </FrameLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>