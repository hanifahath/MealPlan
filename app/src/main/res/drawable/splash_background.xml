<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background warm cream -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFAF7"/>
        </shape>
    </item>

    <!-- Lingkaran besar dekoratif di kanan atas -->
    <item
        android:top="-180dp"
        android:right="-180dp"
        android:bottom="340dp"
        android:left="120dp">
        <shape android:shape="oval">
            <solid android:color="#FFF3E0"/>
        </shape>
    </item>

    <!-- Lingkaran kecil dekoratif di kiri bawah -->
    <item
        android:top="380dp"
        android:right="200dp"
        android:bottom="-80dp"
        android:left="-80dp">
        <shape android:shape="oval">
            <solid android:color="#FBE9E7"/>
        </shape>
    </item>

    <!-- Icon utama di tengah -->
    <item
        android:top="200dp"
        android:right="120dp"
        android:bottom="240dp"
        android:left="120dp"
        android:drawable="@drawable/ic_splash_logo"/>

</layer-list>
