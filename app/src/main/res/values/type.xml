<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Text.Display" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">@font/plus_jakarta_sans_extrabold</item>
        <item name="fontFamily">@font/plus_jakarta_sans_extrabold</item>
        <item name="android:textSize">27sp</item>
        <item name="android:letterSpacing">-0.01</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Text.Title" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">@font/plus_jakarta_sans_bold</item>
        <item name="fontFamily">@font/plus_jakarta_sans_bold</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Text.Subtitle" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">@font/plus_jakarta_sans_semibold</item>
        <item name="fontFamily">@font/plus_jakarta_sans_semibold</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Text.Body" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">@font/plus_jakarta_sans_regular</item>
        <item name="fontFamily">@font/plus_jakarta_sans_regular</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">3sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="Text.Caption" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">@font/plus_jakarta_sans_medium</item>
        <item name="fontFamily">@font/plus_jakarta_sans_medium</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="Text.Overline" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">@font/plus_jakarta_sans_bold</item>
        <item name="fontFamily">@font/plus_jakarta_sans_bold</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/text_tertiary</item>
    </style>

</resources>